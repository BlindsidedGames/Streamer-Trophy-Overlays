{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": false,
    "outDir": "build",
    "rootDir": ".",
    "types": ["node", "vitest/globals"]
  },
  "include": ["server", "shared"],
  "exclude": ["server/**/*.test.ts"]
}
